{
  "name": "power-meter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "pm2": "pm2",
    "gulp": "gulp",
    "start": "node ./bin/www",
    "start:staging": "pm2 start",
    "dev": "concurrently \"pm2 start\" \"gulp\"",
    "monitor": "pm2 monit",
    "reload-env": "pm2 reload --update-env ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "delete": "pm2 delete ecosystem.config.js",
    "knex": "knex --knexfile ./db/knexfile.js --debug"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "browser-sync": "^3.0.3",
    "concurrently": "^9.1.2",
    "connect-redis": "^3.4.2",
    "cookie-parser": "^1.4.7",
    "debug": "^4.4.0",
    "del": "^6.1.1",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "gulp": "^5.0.0",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-sass": "^5.1.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-uglify": "^3.0.2",
    "http-errors": "^2.0.0",
    "joi": "^17.13.3",
    "knex": "^3.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pm2": "^5.4.3",
    "postcss-flexbugs-fixes": "^5.0.2",
    "sass": "^1.83.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1"
  },
  "lint-staged": {
    "**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --config .prettierrc --write"
    ]
  }
}
